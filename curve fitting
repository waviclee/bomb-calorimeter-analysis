"""
Curve Fitting: Exponential Cooling Model
==========================================
Uses scipy.optimize.curve_fit to fit Newton's Law of Cooling to the
Pre-Period and Post-Period temperature-time data:

    T(t) = T_inf + A * exp(-k * (t - t0))

where:
    T_inf = asymptotic (jacket-equilibrium) temperature
    A     = initial offset from T_inf
    k     = cooling/warming rate constant (1/s)
    t0    = reference time (first sample of the phase, for numerical stability)

Why this matters
-----------------
The Regnault-Pfaundler correction (rp_correction.py) assumes a *constant*
linear drift rate (r1, r2) across the Pre- and Post-Period. That is a good
approximation only if the vessel is already close to thermal equilibrium
with the jacket during those windows. If it is still relaxing exponentially
toward equilibrium, a constant linear rate under- or over-estimates the
heat leak depending on where in the exponential curve the "window" sits.

This module fits the full exponential model instead, so:
  1. You can check whether a linear approximation is even justified
     (compare R^2 of linear vs exponential fit).
  2. You can extract an *instantaneous* drift rate at any given time
     (the derivative of the exponential, dT/dt = -k*A*exp(-k*(t-t0))),
     rather than a single constant rate. This instantaneous rate can be
     substituted into the R-P correction at time b for a more accurate
     result than using the constant linear r1 / r2.
"""

import os
import numpy as np
import pandas as pd
from scipy.optimize import curve_fit
from scipy.stats import linregress


def load_sensor_data(file_path):
    df = pd.read_csv(file_path, comment='*')
    df.columns = df.columns.str.strip()
    return df


def exponential_model(t, T_inf, A, k, t0):
    """Newton's Law of Cooling: T(t) = T_inf + A * exp(-k*(t - t0))"""
    return T_inf + A * np.exp(-k * (t - t0))


def fit_exponential(df, phase_label, time_col='Time(s)', temp_col='Vessel_Temp(C)'):
    """
    Fits the exponential cooling model to a given phase's data.
    Returns fitted parameters, their 1-sigma uncertainties, and the fit R^2.
    """
    phase_df = df[df['Phase'] == phase_label].sort_values(time_col)
    t = phase_df[time_col].to_numpy(dtype=float)
    T = phase_df[temp_col].to_numpy(dtype=float)

    if len(t) < 4:
        raise ValueError(f"Need at least 4 points to fit 3 free parameters in phase '{phase_label}'.")

    t0 = t[0]
    # Initial guesses: T_inf ~ last point, A ~ (first - last), k ~ small positive
    T_inf0 = T[-1]
    A0 = T[0] - T[-1]
    k0 = 1e-3

    popt, pcov = curve_fit(
        lambda tt, T_inf, A, k: exponential_model(tt, T_inf, A, k, t0),
        t, T, p0=[T_inf0, A0, k0], maxfev=10000
    )
    T_inf, A, k = popt
    perr = np.sqrt(np.diag(pcov))

    # R^2 for the exponential fit
    T_pred = exponential_model(t, T_inf, A, k, t0)
    ss_res = np.sum((T - T_pred) ** 2)
    ss_tot = np.sum((T - np.mean(T)) ** 2)
    r2_exp = 1 - ss_res / ss_tot if ss_tot > 0 else float("nan")

    # R^2 for a simple linear fit, for comparison
    lin = linregress(t, T)
    r2_lin = lin.rvalue ** 2

    return {
        "T_inf": T_inf, "A": A, "k": k, "t0": t0,
        "T_inf_err": perr[0], "A_err": perr[1], "k_err": perr[2],
        "r2_exponential": r2_exp,
        "r2_linear": r2_lin,
        "linear_slope": lin.slope,
    }


def instantaneous_rate(fit_result, t):
    """dT/dt of the fitted exponential at time t (deg/s)."""
    T_inf, A, k, t0 = (fit_result["T_inf"], fit_result["A"],
                        fit_result["k"], fit_result["t0"])
    return -k * A * np.exp(-k * (t - t0))


def main():
    file_path = os.path.join("data", "sample_data.csv")
    df = load_sensor_data(file_path)

    print("=" * 60)
    print("   EXPONENTIAL COOLING FIT vs LINEAR FIT COMPARISON")
    print("=" * 60)

    for phase in ["Pre-Period", "Post-Period"]:
        try:
            fit = fit_exponential(df, phase)
        except ValueError as e:
            print(f"[{phase}] Skipped: {e}")
            continue

        print(f"\n[{phase}]")
        print(f"  T_inf = {fit['T_inf']:.4f} +/- {fit['T_inf_err']:.4f} C")
        print(f"  A     = {fit['A']:.4f} +/- {fit['A_err']:.4f} C")
        print(f"  k     = {fit['k']:.6f} +/- {fit['k_err']:.6f} 1/s")
        print(f"  R^2 (exponential fit) = {fit['r2_exponential']:.6f}")
        print(f"  R^2 (linear fit)      = {fit['r2_linear']:.6f}")

        if fit['r2_exponential'] - fit['r2_linear'] > 1e-4:
            print("  -> Exponential model fits meaningfully better than linear;")
            print("     consider using instantaneous_rate() in the R-P correction.")
        else:
            print("  -> Linear approximation is adequate for this phase/window.")

        # Example: instantaneous rate at the first and last sample of the phase
        phase_df = df[df['Phase'] == phase]
        t_first = phase_df['Time(s)'].iloc[0]
        t_last = phase_df['Time(s)'].iloc[-1]
        print(f"  Instantaneous dT/dt at t={t_first:.0f}s: {instantaneous_rate(fit, t_first):.6f} C/s")
        print(f"  Instantaneous dT/dt at t={t_last:.0f}s : {instantaneous_rate(fit, t_last):.6f} C/s")
        print(f"  (constant linear rate used elsewhere    : {fit['linear_slope']:.6f} C/s)")

    print("\n" + "=" * 60)


if __name__ == "__main__":
    main()
